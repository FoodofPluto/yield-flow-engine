# Replace with your actual admin email(s), comma-separated
ADMIN_EMAILS=d.arvelop93@gmail.com

# Optional local bypass while developing
DEV_MODE=false

# Optional custom DB path
FURUFLOW_DB_PATH=furuflow.db

# Stripe settings for production webhook/backend
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Telegram auto-posting
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890
FURUFLOW_SIGNAL_SOURCE=defillama
FURUFLOW_SIGNAL_MIN_TVL=1000000
FURUFLOW_SIGNAL_MIN_APY=8
FURUFLOW_SIGNAL_MAX_APY=200
FURUFLOW_SIGNAL_MIN_RISK=0
FURUFLOW_SIGNAL_MAX_RISK=100
FURUFLOW_SIGNAL_MIN_STRENGTH=0
FURUFLOW_SIGNAL_MAX_STRENGTH=100
FURUFLOW_SIGNAL_TOP_N=5
FURUFLOW_SIGNAL_SCAN_DEPTH=250
FURUFLOW_SIGNAL_DEBUG=false
FURUFLOW_SIGNAL_MAX_POSTS=3
FURUFLOW_SIGNAL_CHAINS=base,arbitrum,optimism,polygon,ethereum
FURUFLOW_SIGNAL_STABLECOIN_ONLY=false
FURUFLOW_SIGNAL_ALLOW_REPOSTS=false
FURUFLOW_SIGNAL_DEDUPE_HOURS=24
FURUFLOW_SIGNAL_DRY_RUN=false
FURUFLOW_POSTED_SIGNALS_FILE=posted_signals.json

# Telegram transport tuning
TELEGRAM_CONNECT_TIMEOUT=10
TELEGRAM_READ_TIMEOUT=45
TELEGRAM_RETRY_COUNT=3
TELEGRAM_RETRY_SLEEP_SECONDS=5
TELEGRAM_DISABLE_SSL_VERIFY=false
TELEGRAM_ENABLE_POWERSHELL_FALLBACK=true


# Signal alerts
FURUFLOW_ENABLE_ALERTS=true
FURUFLOW_ALERT_MIN_SCORE=70
FURUFLOW_ALERT_MIN_APY=25
FURUFLOW_ALERT_MIN_TVL=1000000
FURUFLOW_ALERT_MIN_TREND=20

# X posting (set live=false first and review x_post_outbox.txt)
FURUFLOW_X_MODE=signals
FURUFLOW_X_MAX_POSTS=2
FURUFLOW_X_POST_LIVE=false
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret
